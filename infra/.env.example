# TrendBurada — meta-stack environment.
# Copy to infra/.env (gitignored) and adjust the values for your machine.
# These feed the `app` (backend) container in docker-compose.yml.

# ── Spring profile / config server ────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=docker
CONFIG_SERVER_URI=http://config-server:8888

# ── Backend datasource ────────────────────────────────────────────────────────
# Inside compose the backend reaches postgres via the service hostname `postgres-app`.
# If you ever run the backend OUTSIDE compose pointing at the compose Postgres, swap
# the host to `localhost`.
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres-app:5432/trend_burada_app
SPRING_DATASOURCE_USERNAME=trend
SPRING_DATASOURCE_PASSWORD=trend

# ── Keycloak ──────────────────────────────────────────────────────────────────
# Inside compose the BE talks to keycloak by container name on its container port (8080).
# (The host-port mapping 8081 is only for your browser at http://localhost:8081.)
KEYCLOAK_BASE_URL=http://keycloak:8080
KEYCLOAK_REALM=trend-burada
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_CLIENT_ID=trend-burada-web
KEYCLOAK_CLIENT_SECRET=

# ── Mail (mailpit catches everything in dev — UI at http://localhost:8025) ───
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS=false

# ── Auth verification mail ────────────────────────────────────────────────────
AUTH_VERIFICATION_SENDER_NAME=TrendBurada
AUTH_VERIFICATION_SENDER_EMAIL=no-reply@trendburada.com

# ── CORS ──────────────────────────────────────────────────────────────────────
# FE runs at :3000 (compose, nginx) or :5173 (Vite dev). Add your dev hosts here.
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://trendburada.local,http://seller.trendburada.local,http://admin.trendburada.local,http://app.trendburada.local
